# Copy to .env and fill in. Never commit .env.

# --- Backend ---
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Postgres (matches docker-compose service name)
DATABASE_URL=postgresql+asyncpg://aios:aios@postgres:5432/aios

# Redis / Qdrant / MinIO (used from M2 onward; defined now for compose)
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- LLM providers ---
# Local dev default: ollama (free, offline, no API key needed).
# Switch to "auto" for the production Groq->Gemini chain.
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=

# Local: Ollama. Runs on the host, so containers reach it via host.docker.internal.
# For local (non-Docker) uvicorn, use http://localhost:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# Production primary: Groq — free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Production fallback: Google Gemini — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# Optional
# ANTHROPIC_API_KEY=sk-ant-...

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
